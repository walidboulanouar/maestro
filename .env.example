# Maestro runs with NO config (built-in mock provider). Add a key to route to real models.
# Copy to .env (gitignored) or just export these.

# --- Providers (bring your own key; pick any) ---
# OpenRouter — 400+ open + closed models
OPENROUTER_API_KEY=

# Vercel AI Gateway — 0% markup, also serves sakana/fugu-ultra
AI_GATEWAY_API_KEY=

# Local OpenAI-compatible server (Ollama / vLLM / llama.cpp / LM Studio) — 100% offline
# LOCAL_OPENAI_BASE_URL=http://localhost:11434/v1
# LOCAL_OPENAI_API_KEY=

# --- Server ---
# MAESTRO_PORT=8080
# MAESTRO_DEFAULT_MODE=fugu          # auto | fugu | ultra
# MAESTRO_MAX_TURNS=3
# MAESTRO_VERIFY=true
# MAESTRO_DIFFICULTY_LOW=0.33
# MAESTRO_DIFFICULTY_HIGH=0.7

# --- Registry / tracing ---
# MAESTRO_REGISTRY=./maestro.config.json   # your own model registry
# MAESTRO_TRACE_FILE=./traces/maestro.jsonl

# --- Demo: route the priced registry but execute on the mock provider (no spend) ---
# MAESTRO_FORCE_MOCK=true
